# ==================== 기본 ====================
PORT=4000
DB_PATH=./data/smartfarm.db
NODE_ENV=development
LOG_LEVEL=info
JWT_SECRET=change-me-to-a-long-random-string    # openssl rand -hex 32
SEED_DEMO=true                                    # prod=false
PUBLIC_URL=http://localhost:5173                  # 이메일 링크·결제 리다이렉트 기준

# ==================== CORS ====================
# 쉼표 구분. 프로덕션에서는 도메인 화이트리스트 필수.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# ==================== 이메일 (SMTP) ====================
# 미설정 시 비밀번호 재설정 메일은 서버 콘솔에 출력
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
# FROM_EMAIL=noreply@smartfarm.kr
# FROM_NAME=🍓 스마트팜

# ==================== 기상청 API ====================
# 신청: data.go.kr → 기상청_단기예보((구)_초단기예보조회서비스)
# KMA_API_KEY=your-kma-decoded-service-key

# ==================== Claude API (병해 진단) ====================
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-7

# ==================== 토스페이먼츠 (구독 결제) ====================
# 테스트: test_ck_xxx / test_sk_xxx  |  운영: live_ck_xxx / live_sk_xxx
# TOSS_CLIENT_KEY=test_ck_...
# TOSS_SECRET_KEY=test_sk_...

# ==================== 카카오 알림톡 (Solapi) ====================
# 가입: https://solapi.com
# KAKAO_ALIMTALK_API_KEY=
# KAKAO_ALIMTALK_API_SECRET=
# KAKAO_PFID=                    카카오 비즈 플러스친구 ID
# KAKAO_FROM_PHONE=0212345678   발신번호 (solapi 에 등록된 번호)
# KAKAO_TEMPLATE_ALERT=         알림 템플릿 ID

# ==================== Sentry (에러 추적) ====================
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ==================== PostgreSQL (스케일 시) ====================
# DATABASE_URL=postgres://user:pass@host:5432/smartfarm

# ==================== Web Push VAPID ====================
# 최초 기동 시 data/vapid.json 에 자동 생성. 여기 직접 설정도 가능.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@smartfarm.kr

# ==================== 에너지 요금 ====================
KWH_PRICE_KRW=200
